# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.coverage
.coverage.*
htmlcov/

# Virtual environments
.venv/
venv/
env/
ENV/

# Build and packaging output
build/
dist/
*.egg-info/
.eggs/

# Terraform local state/cache
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
crash.log
crash.*.log

# Editor and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Local scratch/example projects
testprojectignore/
*.blab.json

#gmsh examples
gmsh/gmsh-4.15.2-Windows64/examples/

# Generated BEM solver outputs and run directories
runs/
pressure_data*.npz
pressure_data_formatted.npz
horizontal_isobar.png
vertical_isobar.png
acoustic_impedance.png
*_clean.msh

# Keep curated documentation example artifacts trackable.
!docs/examples/**/*.npz
!docs/examples/**/*.png
!docs/examples/**/*_clean.msh
